# 单元测试 / CI 专用环境变量（勿用于生产）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=game_account_exchange
MYSQL_CONNECT_TIMEOUT_SECONDS=5
MYSQL_READ_TIMEOUT_SECONDS=10
MYSQL_WRITE_TIMEOUT_SECONDS=10
MYSQL_POOL_SIZE=2

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_BACKEND_USERNAME=payment_backend_test
REDIS_BACKEND_PASSWORD=test_backend_redis_password
REDIS_GATEWAY_USERNAME=payment_gateway_test
REDIS_GATEWAY_PASSWORD=test_gateway_redis_password
REDIS_CONNECT_TIMEOUT_SECONDS=5
REDIS_COMMAND_TIMEOUT_SECONDS=5
REDIS_POOL_SIZE=2

JWT_ALGORITHM=HS256
JWT_SECRET=test_jwt_secret_at_least_32_chars_long
JWT_QR_TOKEN_TTL_SECONDS=1
JWT_CLOCK_SKEW_SECONDS=0

USER_EMAIL_HASH_SECRET=test_email_hash_secret
USER_ID_CARD_HASH_SECRET=test_id_card_hash_secret
PASSWORD_HASH_SECRET=test_password_hash_secret

DEBUG=true

PAYMENT_BACKEND_HTTP_PORT=9990
PAYMENT_BACKEND_WEBSOCKET_PORT=9991
PAYMENT_BACKEND_IP=localhost

PAYMENT_GATEWAY_WEBSOCKET_PORT=9992
PAYMENT_GATEWAY_HTTP_PORT=9993
PAYMENT_GATEWAY_IP=127.0.0.1

PAYMENT_SCAN_PAGE_PATH=/payment/scan
PAYMENT_NGINX_PORT=9994
PAYMENT_NGINX_IP=127.0.0.1

LOGIN_SESSION_TTL_SECONDS=300
PAYMENT_SESSION_TTL_SECONDS=300
PAYMENT_ATTEMPT_REQUEST_TTL_SECONDS=300
WEBSOCKET_HEARTBEAT_INTERVAL_SECONDS=30
WEBSOCKET_IDLE_TIMEOUT_SECONDS=90
LOGIN_REAUTH_MAX_RETRY=5

LOG_FILE=/tmp/payment_backend_test.log
LOG_MAX_FILE_SIZE=1048576
LOG_MAX_FILES=2
LOG_CONSOLE_ENABLED=false
