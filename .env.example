# MySQL Configuration
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=game_backend
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=game_account_exchange
MYSQL_CONNECT_TIMEOUT_SECONDS=5
MYSQL_READ_TIMEOUT_SECONDS=10
MYSQL_WRITE_TIMEOUT_SECONDS=10
MYSQL_POOL_SIZE=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# 使用 Redis ACL 创建两个账号：
# ACL SETUSER payment_backend on >your_backend_redis_password ~payment:session:* +ping +select +get +set +del +exists
# ACL SETUSER payment_gateway on >your_gateway_redis_password ~payment:session:* +ping +select +get
REDIS_BACKEND_USERNAME=payment_backend
REDIS_BACKEND_PASSWORD=your_backend_redis_password
REDIS_GATEWAY_USERNAME=payment_gateway
REDIS_GATEWAY_PASSWORD=your_gateway_redis_password
REDIS_CONNECT_TIMEOUT_SECONDS=5
REDIS_COMMAND_TIMEOUT_SECONDS=5
REDIS_POOL_SIZE=4

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_SECRET=your_jwt_secret_at_least_32_chars
JWT_QR_TOKEN_TTL_SECONDS=300
JWT_CLOCK_SKEW_SECONDS=30

# User Email Hash Configuration
USER_EMAIL_HASH_SECRET=your_email_hash_secret

# User ID Card Hash Configuration
USER_ID_CARD_HASH_SECRET=your_id_card_hash_secret

# Password Hash Configuration
PASSWORD_HASH_SECRET=your_password_hash_secret

# Environment Configuration
DEBUG=true

# Payment Service backend Configuration
# 后端进程 bind 地址在代码中固定为 0.0.0.0；此处为网关转发时连接的后端主机名/IP。
PAYMENT_BACKEND_HTTP_PORT=9990
PAYMENT_BACKEND_WEBSOCKET_PORT=9991 # Reserved port, temporarily unused
PAYMENT_BACKEND_IP=localhost

# Payment Service Gateway Configuration (鉴权、限流)
# 网关进程 bind 地址在代码中固定为 0.0.0.0；此处为返回给客户端的可访问主机名/IP。
PAYMENT_GATEWAY_WEBSOCKET_PORT=9992
PAYMENT_GATEWAY_HTTP_PORT=9993
PAYMENT_GATEWAY_IP=127.0.0.1

# Payment Service frontend url（手机扫码支付页路径，由 Nginx 提供，不含 query）
PAYMENT_SCAN_PAGE_PATH=/payment/scan

# Payment Service nginx Configuration
# Nginx 进程 bind 地址在代码中固定为 0.0.0.0；此处为浏览器打开前端页面的可访问主机名/IP。
PAYMENT_NGINX_PORT=9994
PAYMENT_NGINX_IP=127.0.0.1

# Payment Runtime Configuration
LOGIN_SESSION_TTL_SECONDS=86400
PAYMENT_SESSION_TTL_SECONDS=300
PAYMENT_ATTEMPT_REQUEST_TTL_SECONDS=300
WEBSOCKET_HEARTBEAT_INTERVAL_SECONDS=30
WEBSOCKET_IDLE_TIMEOUT_SECONDS=90
LOGIN_REAUTH_MAX_RETRY=5

# HTTP Server Configuration (Backend / Gateway)
HTTP_WORKER_THREADS=20
HTTP_LISTEN_BACKLOG=128
HTTP_MAX_CONCURRENT_CONNECTIONS=256
HTTP_READ_TIMEOUT_SECONDS=10

# Gateway WebSocket Configuration
WS_MAX_CONNECTIONS=256

# Logger Configuration
LOG_FILE=/tmp/payment_backend.log
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=5
LOG_CONSOLE_ENABLED=true